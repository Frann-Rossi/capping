---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Sistema de Reservas de Turnos" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-gray-50 text-gray-900 min-h-screen font-sans">
		<main class="max-w-md mx-auto px-4 py-8">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	@import "tailwindcss";

	:root {
		--primary: #3b82f6;
		--primary-hover: #2563eb;
	}

	.btn {
		@apply w-full py-3 px-4 rounded-xl font-semibold transition-all duration-200 active:scale-95;
	}

	.btn-primary {
		@apply bg-blue-600 text-white hover:bg-blue-700 shadow-lg shadow-blue-200;
	}

	.input-field {
		@apply w-full p-4 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all;
	}
</style>
